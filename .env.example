# Zkopíruj do .env a vyplň hodnotami z Project Settings → API v Supabase.
# anon klíč je veřejný (chrání ho RLS). service_role klíč sem NIKDY nedávej.
VITE_SUPABASE_URL=https://tvuj-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=tvuj-anon-public-klic

# Open-Meteo: volitelné – vyplň až přejdeš na komerční licenci.
# Bez těchto hodnot se používá bezplatný endpoint (výchozí).
# VITE_OPENMETEO_BASE=https://customer-api.open-meteo.com
# VITE_OPENMETEO_ENSEMBLE_BASE=https://customer-ensemble-api.open-meteo.com
# VITE_OPENMETEO_KEY=tvuj-klic

# Pro Netlify funkce (nastav v Netlify UI → Site → Environment variables):
# OPENMETEO_BASE=https://customer-api.open-meteo.com
# OPENMETEO_ENSEMBLE_BASE=https://customer-ensemble-api.open-meteo.com
# OPENMETEO_KEY=tvuj-klic
